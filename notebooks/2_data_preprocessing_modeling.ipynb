   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"../data/faang_stock_prices.csv\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "3e0e9ab7-d144-427c-ad9f-93f85b02d03c",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = df.sort_values([\"Ticker\", \"Date\"])\n",
    "\n",
    "df[\"Next_Day_Close\"] = df.groupby(\"Ticker\")[\"Close\"].shift(-1)\n",
    "\n",
    "X = df.drop(\"Next_Day_Close\", axis=1)\n",
    "y = df[\"Next_Day_Close\"]"
   ]
